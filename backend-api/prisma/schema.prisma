generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String         @id @default(uuid())
  supabaseAuthId String         @unique
  email          String         @unique
  name           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  feedbacks      ScanFeedback[]
  scans          ScanHistory[]
}

model ScanHistory {
  id             String         @id @default(uuid())
  userId         String
  imageUrl       String
  foodType       String
  safetyLevel    String
  aiConfidence   Float
  aiResponseJson Json
  createdAt      DateTime       @default(now())
  userNote       String?
  latitude       Float?
  longitude      Float?
  feedbacks      ScanFeedback[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model ScanFeedback {
  id        String      @id @default(uuid())
  scanId    String
  userId    String
  issueType String
  comment   String?
  rating    Int?        // Rating 1-100 (from 1-5 star scale)
  createdAt DateTime    @default(now())
  scan      ScanHistory @relation(fields: [scanId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([userId])
}
