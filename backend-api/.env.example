# ─── Gin dai MAI! Backend — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your actual values

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase PostgreSQL ─────────────────────────────────────────────────────
# Transaction pooler URL (for Prisma ORM runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (for Prisma Migrate)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── Supabase Project ────────────────────────────────────────────────────────
# Found at: Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ⚠️ NEVER commit this key — backend only
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
