FROM node:20-alpine

WORKDIR /app

# Install dependencies (with legacy-peer-deps for React 19 compatibility)
COPY package*.json ./
RUN npm install --legacy-peer-deps

# Copy all source files
COPY . .

# Expose Metro bundler + Expo Devtools ports
EXPOSE 8081 19000 19001 19002

# REACT_NATIVE_PACKAGER_HOSTNAME must be set at runtime to the HOST machine's IP
# so the phone can reach the Metro bundler from outside the container
CMD ["npx", "expo", "start", "--host", "lan"]
